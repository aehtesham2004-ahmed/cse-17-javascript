<!DOCTYPE html>
<html>
<head>
    <title>Student Result</title>
</head>
<body>

<h1>Student Result Program</h1>

<input type="number" id="subjects" placeholder="Enter Subjects">
<button onclick="calculate()">Calculate</button>

<div id="output"></div>

<script>
function calculate() {
    let total = 436;
    let average = total / 6;
    let grade;

    if (average >= 70)
        grade = "A";
    else if (average >= 60)
        grade = "B";
    else
        grade = "C";

    document.getElementById("output").innerHTML =
        "Total Marks = " + total + "<br>" +
        "Average = " + average + "<br>" +
        "Grade = " + grade;
}
</script>

</body>
</html>
